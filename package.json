    "@types/tmp": "^0.2.6",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@huggingface/jinja": "^0.5.9",
    "commander": "^15.0.0",
    "confbox": "^0.2.4",
    "fs-extra": "^11.3.6",
    "koffi": "^3.1.0",
    "sprintf-js": "^1.1.3",
    "tmp": "^0.2.7",
    "yurandom": "^1.0.0",
    "zod": "^4.4.3"
